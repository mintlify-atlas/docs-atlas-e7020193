  "keyFeatures": [
    "Real-time US AQI monitoring for any location worldwide",
    "Detailed pollutant tracking (PM2.5, PM10, NO₂, SO₂, O₃, CO)",
    "Pollen and allergy monitoring (grass, tree, weed)",
    "Historical climate trend analysis",
    "City search with autocomplete",
    "Location-based air quality data",
    "Dark mode support",
    "Health tips based on AQI levels"
  ],
  "publicApiSurface": [
    "AirQualityService.fetchAirQuality(latitude:longitude:)",
    "GeocodingService.searchCities(query:)",
    "PollenService.fetchPollen(latitude:longitude:)",
    "ClimateService.fetchClimateData(latitude:longitude:)",
    "DashboardViewModel.requestLocation()",
    "DashboardViewModel.searchCities(_:)",
    "DashboardViewModel.selectCity(_:)",
    "DashboardViewModel.fetchAllData(latitude:longitude:)",
    "AQIStatus.from(aqi:)",
    "Color.appBackground",
    "Color.aqiGood",
    "Color.aqiModerate",
    "Color.aqiUnhealthySensitive",
    "Color.aqiUnhealthy",
    "Color.aqiVeryUnhealthy",
    "Color.aqiHazardous"
  ]
